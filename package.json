{
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "description": "MetriGo — full-stack transit intelligence platform (commute fares, routing, city transit insights)",
  "homepage": "https://github.com/rishitaraj14/MetriGo",
  "repository": {
    "type": "git",
